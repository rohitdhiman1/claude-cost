{
  "name": "claude-cost",
  "version": "0.1.0",
  "description": "Track and report Claude Code session costs via silent hooks",
  "type": "module",
  "bin": {
    "claude-cost": "./dist/cli.js"
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "dev": "node esbuild.config.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "claude",
    "anthropic",
    "claude-code",
    "cost",
    "tokens",
    "usage",
    "cli"
  ],
  "author": "Rohit Dhiman <rohitdhiman0202@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rohitdhiman1/claude-cost.git"
  },
  "homepage": "https://github.com/rohitdhiman1/claude-cost#readme",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.7.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
